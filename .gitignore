@'
# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Environment files
.env
client/.env
server/.env
*.env

# Build outputs
dist/
build/
client/dist/
server/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Temp files
server/temp/
*.tmp

# IDE
.vscode/
.idea/
*.swp
*.swo
'@ | Out-File -FilePath ".gitignore" -Encoding utf8